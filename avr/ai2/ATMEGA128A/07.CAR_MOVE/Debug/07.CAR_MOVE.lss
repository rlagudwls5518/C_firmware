// 모터 초기화 함수
void motor_init() {
	// PORTF의 0, 1, 2, 3번 핀을 출력(1)으로 설정 (IN1 ~ IN4)
	DDRF |= (1 << IN1) | (1 << IN2) | (1 << IN3) | (1 << IN4);
